# Supabase (local dev, run by `supabase start`)
#
# Auth keys are NOT committed here: newer Supabase CLIs generate per-instance
# signing keys, so the anon/service_role values differ on every machine.
# `make up` reads the live keys from `supabase start` and injects them
# automatically (see scripts/supabase-env.sh) -- you do NOT need to fill these in.
# They only matter if you bypass make and run `docker compose up` directly, in
# which case run `make supabase-status` and paste the real values here.
#
# Two URLs intentionally differ by run context:
#   SUPABASE_URL       -> used by the Temporal worker, which runs INSIDE Docker and
#                         reaches the host-bound Supabase via host.docker.internal.
#   VITE_SUPABASE_URL  -> used by the frontend, which runs in the browser on the HOST.
SUPABASE_URL=http://host.docker.internal:54321
SUPABASE_ANON_KEY=injected-by-make-up
SUPABASE_SERVICE_ROLE_KEY=injected-by-make-up

# Temporal
TEMPORAL_ADDRESS=temporal:7233
TEMPORAL_NAMESPACE=default
TEMPORAL_TASK_QUEUE=main

# Frontend (browser on the host -> localhost)
VITE_SUPABASE_URL=http://localhost:54321
VITE_SUPABASE_ANON_KEY=injected-by-make-up
VITE_API_URL=http://localhost:54321/functions/v1

# Azure AI Foundry (model inference)
#
# Resource: aif-mawf-ives-dev-sc (resource group Ives_IA, region swedencentral)
# Do NOT commit the real key. Fill AZURE_AI_API_KEY in your local .env only.
# Retrieve it with:
#   az cognitiveservices account keys list -n aif-mawf-ives-dev-sc -g Ives_IA --query key1 -o tsv
#
# Foundry project endpoint (Azure AI Projects / Agents SDK):
AZURE_AI_FOUNDRY_PROJECT_ENDPOINT=https://aif-mawf-ives-dev-sc.services.ai.azure.com/api/projects/proj-mawf-ives-dev-sc
# Model inference endpoint (azure-ai-inference / chat + Anthropic/Cohere/Mistral models):
AZURE_AI_INFERENCE_ENDPOINT=https://aif-mawf-ives-dev-sc.services.ai.azure.com/
# Azure OpenAI endpoint (OpenAI-format models, e.g. embeddings):
AZURE_OPENAI_ENDPOINT=https://aif-mawf-ives-dev-sc.openai.azure.com/
AZURE_OPENAI_API_VERSION=2024-10-21
AZURE_ANTHROPIC_API_VERSION=2025-04-01-preview
# API key (leave blank here; set the real value in local .env):
AZURE_AI_API_KEY=
# Deployments:
AZURE_AI_CHAT_DEPLOYMENT=claude-sonnet-4-6
AZURE_AI_EMBEDDING_DEPLOYMENT=text-embedding-3-large
# Claude *Sonnet 4.6* deployment used by the AI document summarization feature
# (French -> English). Defaults to the verified claude-sonnet-4-6 deployment; the
# Temporal worker reads this via AZURE_AI_SUMMARY_DEPLOYMENT.
AZURE_AI_SUMMARY_DEPLOYMENT=claude-sonnet-4-6
# Toggle the summarization intake poller in the worker (default true):
AI_SUMMARIZATION_ENABLED=true
#
# Verified call patterns:
#   Claude chat (Anthropic Messages API):
#     POST {AZURE_AI_INFERENCE_ENDPOINT}anthropic/v1/messages?api-version=${AZURE_ANTHROPIC_API_VERSION}
#     headers: x-api-key: <AZURE_AI_API_KEY>, anthropic-version: 2023-06-01
#     body: {"model":"claude-sonnet-4-6","max_tokens":...,"messages":[...]}
#   Embeddings (Azure OpenAI):
#     POST {AZURE_OPENAI_ENDPOINT}openai/deployments/text-embedding-3-large/embeddings?api-version=${AZURE_OPENAI_API_VERSION}
#     headers: api-key: <AZURE_AI_API_KEY>; body: {"input":"..."}
